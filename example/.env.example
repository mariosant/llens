# Environment variables for llens
# Copy this file to .env and fill in your API keys

# Provider API keys (required)
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GOOGLE_API_KEY=...

# Default configuration (optional - can also be set in llens.config.yml)
# LLENS_PROVIDER=openai
# LLENS_MODEL=gpt-4
# LLENS_TEMPERATURE=0.7
# LLENS_TIMEOUT=30000
# LLENS_FAIL_FAST=false
