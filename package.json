{
  "name": "llens",
  "module": "./src/cli.ts",
  "type": "module",
  "version": "0.1.0",
  "description": "LLM Quality Assurance Test Runner",
  "repository": "github:mariosant/llens",
  "bin": {
    "llens": "./src/cli.ts"
  },
  "scripts": {
    "dev": "bun --hot ./src/cli.ts",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "build": "bun build --compile --outfile dist/llens ./src/cli.ts",
    "build:linux-x64": "bun build --compile --outfile dist/llens-linux-x64 ./src/cli.ts",
    "build:linux-arm64": "bun build --compile --outfile dist/llens-linux-arm64 ./src/cli.ts",
    "build:darwin-x64": "bun build --compile --outfile dist/llens-darwin-x64 ./src/cli.ts",
    "build:darwin-arm64": "bun build --compile --outfile dist/llens-darwin-arm64 ./src/cli.ts",
    "build:all": "bun run build:linux-x64 && bun run build:linux-arm64 && bun run build:darwin-x64 && bun run build:darwin-arm64",
    "semantic-release": "semantic-release"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/mocha": "^10.0.6",
    "mocha": "^10.2.0",
    "prettier": "^3.8.1",
    "tsx": "^4.7.0",
    "semantic-release": "^25.0.0",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.0"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.69",
    "@ai-sdk/google": "^3.0.63",
    "@ai-sdk/openai": "^3.0.53",
    "ai": "^6.0.161",
    "c12": "^4.0.0-beta.4",
    "citty": "^0.2.2",
    "confbox": "^0.2.4",
    "franc": "^6.2.0",
    "picocolors": "^1.1.1",
    "zod": "^4.3.6"
  }
}
